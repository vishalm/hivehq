{
  "name": "hive",
  "version": "0.1.0",
  "private": true,
  "description": "HIVE — The Global AI Consumption Network. Scout · Node · Hive.",
  "license": "MIT",
  "repository": "github:vishalm/hivehq",
  "workspaces": [
    "packages/*",
    "connectors/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "clean": "turbo run clean && rm -rf node_modules",
    "postinstall": "node scripts/fix-libsodium.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.4"
}
