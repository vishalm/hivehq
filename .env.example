# ──────────────────────────────────────────────────────────────────────────────
# HIVE — Environment Configuration
# Copy to .env and adjust as needed. All values below are sensible defaults.
# Never commit .env — only .env.example.
# ──────────────────────────────────────────────────────────────────────────────

# ── Node Server ──────────────────────────────────────────────────────────────
NODE_PORT=3000
NODE_REGION=AE
NODE_ID=hive-node-01
# NODE_INGEST_TOKEN=                  # Set a 16+ char token to secure ingest
NODE_DATABASE_URL=postgres://hive:hive_dev_password@localhost:5432/hive
NODE_REDIS_URL=redis://localhost:6379
LOG_LEVEL=info

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3001
DASHBOARD_NODE_URL=http://localhost:3000

# ── Scout ────────────────────────────────────────────────────────────────────
HIVE_DEPLOYMENT=solo                  # solo | node | federated | open
HIVE_CONNECTORS=anthropic,ollama      # Comma-separated: anthropic,ollama,openai,google,mistral,azure_openai,bedrock
HIVE_DATA_RESIDENCY=AE
HIVE_RETENTION_DAYS=90
HIVE_REGULATION_TAGS=UAE_AI_LAW,GDPR
HIVE_FLUSH_INTERVAL_MS=60000
# HIVE_DEPT_TAG=engineering
# HIVE_PROJECT_TAG=copilot-assist
# HIVE_OLLAMA_HOST=localhost:11434    # Override if Ollama is on a different host
# HIVE_NODE_REGION=AE

# For node/federated mode:
# TTP_ENDPOINT=http://localhost:3000/api/v1/ttp/ingest
# TTP_TOKEN=

# ── Docker Compose ───────────────────────────────────────────────────────────
POSTGRES_PASSWORD=hive_dev_password
