# ──────────────────────────────────────────────────────────────────────────────
# HIVE — Environment Reference
#
# Two ready-made configs are provided:
#   .env.local   — for local dev (npm run dev, services on localhost)
#   .env.docker  — for Docker    (docker compose --env-file .env.docker up -d)
#
# Copy the one you need:
#   cp .env.local .env     # local development
#   cp .env.docker .env    # Docker Compose
#
# Or pass directly:
#   docker compose --env-file .env.docker up --build -d
#
# Never commit .env — only .env.example, .env.local, .env.docker.
# ──────────────────────────────────────────────────────────────────────────────

# ── Node Server ──────────────────────────────────────────────────────────────
NODE_PORT=3000                          # Express listen port
NODE_REGION=AE                          # ISO 3166-1 alpha-2 (data residency)
NODE_ID=hive-node-01                    # Unique node identifier
NODE_INGEST_TOKEN=                      # 16+ char token to secure ingest (optional)
LOG_LEVEL=info                          # pino log level: debug | info | warn | error

# ── Database & Cache ─────────────────────────────────────────────────────────
# Local:  localhost URLs
# Docker: service-name URLs (set in docker-compose.yml, not here)
NODE_DATABASE_URL=postgresql://hive:hive_dev_password@localhost:5432/hive
NODE_REDIS_URL=redis://localhost:6379
POSTGRES_PASSWORD=hive_dev_password

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3001                     # Next.js listen port
DASHBOARD_NODE_URL=http://localhost:3000         # Server-side (SSR) fetch URL
NEXT_PUBLIC_NODE_URL=http://localhost:3000        # Client-side (browser) fetch URL
# In Docker: DASHBOARD_NODE_URL = http://node-server:3000  (set in compose)
#            NEXT_PUBLIC_NODE_URL = http://localhost:3000   (browser still hits host)

# ── Scout ────────────────────────────────────────────────────────────────────
HIVE_DEPLOYMENT=solo                    # solo | node | federated | open
HIVE_CONNECTORS=anthropic,ollama        # Comma-separated connector IDs
HIVE_DATA_RESIDENCY=AE
HIVE_RETENTION_DAYS=90
HIVE_REGULATION_TAGS=UAE_AI_LAW,GDPR
HIVE_FLUSH_INTERVAL_MS=60000
# HIVE_DEPT_TAG=engineering
# HIVE_PROJECT_TAG=copilot-assist
# HIVE_OLLAMA_HOST=localhost:11434

# ── TTP Endpoint (for node/federated mode) ──────────────────────────────────
# TTP_ENDPOINT=http://localhost:3000/api/v1/ttp/ingest
# TTP_TOKEN=
