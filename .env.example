# HIVE — Environment Configuration
# Copy to .env and fill in. Never commit .env.

# ── Scout ─────────────────────────────────────────────────────────────────────
# Node Hub endpoint the Scout reports to. Leave blank in solo mode.
HATP_ENDPOINT=https://node.your-org.internal/api/v1/hatp/ingest
HATP_TOKEN=

# Deployment mode · one of: solo | node | federated | open
HIVE_DEPLOYMENT=solo

# Default governance — overridden per org
HIVE_DATA_RESIDENCY=AE
HIVE_RETENTION_DAYS=90
HIVE_REGULATION_TAGS=UAE_AI_LAW,GDPR

# Scout flush cycle in ms
HIVE_FLUSH_INTERVAL_MS=60000

# ── Node Server ───────────────────────────────────────────────────────────────
NODE_PORT=3000
NODE_DATABASE_URL=postgres://hive:hive@localhost:5432/hive_node
NODE_REDIS_URL=redis://localhost:6379
NODE_REGION=AE
NODE_ID=

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3001
DASHBOARD_NODE_URL=http://localhost:3000
