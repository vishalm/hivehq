# HIVE Ollama Proxy — transparent reverse proxy capturing TTP telemetry
FROM node:22-alpine
WORKDIR /app

# Copy workspace root + shared package
COPY package.json package-lock.json* ./
COPY packages/shared/package.json packages/shared/
RUN npm ci --workspace=packages/shared --ignore-scripts 2>/dev/null || npm install --workspace=packages/shared

# Build shared (proxy imports from @hive/shared)
COPY tsconfig.base.json ./
COPY packages/shared/src packages/shared/src
COPY packages/shared/tsconfig.json packages/shared/
RUN npx tsc -p packages/shared/tsconfig.json

# Copy proxy script
COPY scripts/ollama-proxy.mjs ./proxy.mjs

# Ensure node user can read everything
RUN chmod -R a+r /app && chmod a+x /app

USER node
EXPOSE 11435
CMD ["node", "proxy.mjs"]
